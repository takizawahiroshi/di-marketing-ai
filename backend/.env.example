# DI Marketing AI — 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# cp backend/.env.example backend/.env

# ── 必須 ──────────────────────────────────────────────────────
# Anthropic API キー（https://console.anthropic.com/ で取得）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── 本番環境（任意） ──────────────────────────────────────────
# 許可するオリジン（カンマ区切り）。未設定時はローカルのみ許可。
# ALLOWED_ORIGINS=https://ai.digitalidentity.co.jp,https://marketing-ai.digitalidentity.co.jp
